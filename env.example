# ============================================================
# UIABA Bot — Змінні середовища
# Скопіюйте цей файл як .env і заповніть значення
# НЕ завантажуйте .env на GitHub!
# ============================================================

# Токен верифікації webhook (придумайте самі, будь-яке слово)
VERIFY_TOKEN=uiaba_verify_token_2024

# Токен сторінки Facebook (отримати в Meta Developer Portal)
# Розділ: Messenger API Settings → Generate token
PAGE_ACCESS_TOKEN=your_page_access_token_here

# API ключ Claude (отримати на console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Порт (Railway встановлює автоматично)
PORT=3000
